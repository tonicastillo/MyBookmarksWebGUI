# Configuración para scripts/backup-prod.sh
# Copia este archivo a scripts/.env.backup (gitignored) y rellena.

# Host SSH del servidor Dokploy (obligatorio)
DOKPLOY_SSH=usuario@tu-host.com
DOKPLOY_SSH_PORT=22

# Clave privada SSH para autenticarse contra el host.
# Si la dejas vacía, ssh usará tu agente / claves por defecto.
DOKPLOY_SSH_KEY=~/.ssh/id_rsa

# Nombre del contenedor de la app. Si lo dejas vacío, el script
# intenta autodetectarlo por labels de docker-compose.
APP_CONTAINER_NAME=

# Nombre del proyecto compose (lo usa Dokploy para etiquetar contenedores).
# Se usa solo si APP_CONTAINER_NAME está vacío.
COMPOSE_PROJECT=mybookmarks2026

# Ruta del volumen de datos dentro del contenedor.
REMOTE_DATA_PATH=/app/data

# Directorio local donde se guardarán los backups.
LOCAL_BACKUP_DIR=./backups
